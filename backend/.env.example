# Guardian backend (Khushi's half) — copy to .env and fill in as keys arrive from the hackathon Discord
PORT=4000
MOCK=1

# Vocal Bridge — voice calls (server-only secret, never ship to a browser)
VOCAL_BRIDGE_API_KEY=
VOCAL_BRIDGE_AGENT_ID=

# Sabre sandbox — flight/hotel search + booking
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_ENV=cert

# PayPal — SANDBOX ONLY, never live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Demo phone number the agent calls as "the vendor" (our own phone, never a real business)
DEMO_VENDOR_PHONE=
